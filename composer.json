{
  "name": "automattic/simple-x402",
  "description": "Minimal x402 paywall for WordPress.",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "repositories": [
    {
      "type": "path",
      "url": "companions/simple-x402-jetpack",
      "options": { "symlink": true }
    }
  ],
  "require": {
    "php": ">=8.1",
    "jaybizzle/crawler-detect": "^1.3",
    "automattic/simple-x402-jetpack": "@dev"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "squizlabs/php_codesniffer": "^3.9",
    "wp-coding-standards/wpcs": "^3.0",
    "phpcompatibility/phpcompatibility-wp": "^2.1",
    "dealerdirect/phpcodesniffer-composer-installer": "^1.0"
  },
  "autoload": {
    "psr-4": { "SimpleX402\\": "src/" }
  },
  "autoload-dev": {
    "psr-4": {
      "SimpleX402\\Tests\\": "tests/",
      "SimpleX402\\Jetpack\\Tests\\": "companions/simple-x402-jetpack/tests/"
    }
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  },
  "scripts": {
    "test": "phpunit",
    "lint": "phpcs",
    "lint:fix": "phpcbf"
  }
}
